# AWS (Bedrock Cohere embeddings)
AWS_REGION=ap-southeast-1
MODEL_ID=cohere.embed-multilingual-v3
EMBEDDING_DIM=1024
MAX_BATCH_SIZE=96
MAX_CHARS_PER_TEXT=2048

# OpenSearch (local: make up)
OPENSEARCH_URL=http://localhost:9200
INDEX_NAME=nam-documents

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8090
