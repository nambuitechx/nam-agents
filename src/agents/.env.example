# Amazon Bedrock (APAC inference profile)
BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_REGION=ap-southeast-1

# Optional model parameters
# BEDROCK_TEMPERATURE=0.3
# BEDROCK_MAX_TOKENS=4096

# Knowledge base (OpenSearch + Cohere embeddings — same index as src/embedding/)
EMBEDDING_MODEL_ID=cohere.embed-multilingual-v3
EMBEDDING_DIM=1024
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_NAME=nam-documents
KB_SEARCH_TOP_K=5

# AWS credentials (or use `aws configure`)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1

# --- AgentCore Runtime (set by Terraform in deployed container) ---
# These are injected via infra/agent_runtime.tf environment_variables.
# For local runtime testing: uv run python -m runtimes.simple
